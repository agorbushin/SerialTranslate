#!/usr/bin/env bash
# After switching branches: restart bot if Python or deps differ between old and new HEAD.
# $1 = previous HEAD, $2 = new HEAD, $3 = 1 (branch checkout) or 0 (file checkout)
[[ "${3:-0}" == "1" ]] || exit 0
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
exec "$ROOT/.githooks/restart_if_code_changed.sh" "${1:-}" "${2:-}"
