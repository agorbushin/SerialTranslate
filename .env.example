# Copy to ".env" in this folder and fill in values. ".env" is gitignored.
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
OPENSUBTITLES_API_KEY=
# Optional fallback keys used when OpenSubtitles returns auth/quota failures.
OPENSUBTITLES_API_KEY_2=
# Or provide several at once: OPENSUBTITLES_API_KEYS=key1,key2,key3
# Backward-compatible alias also accepted: opensubtitles_api_alternative_key
# Optional only if running daily_trending_subtitles.py with --source trending_day/popular.
TMDB_API_KEY=

# Optional for YouTube caption downloads when YouTube blocks anonymous yt-dlp requests.
# Use one of these on the machine where the bot runs:
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES=/absolute/path/to/cookies.txt
