# Copy to ".env" in this folder and fill in values. ".env" is gitignored.
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
OPENSUBTITLES_API_KEY=
# https://www.themoviedb.org/settings/api — trending / popular TV for daily subtitle runs
TMDB_API_KEY=

# Optional for YouTube caption downloads when YouTube blocks anonymous yt-dlp requests.
# Use one of these on the machine where the bot runs:
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES=/absolute/path/to/cookies.txt
